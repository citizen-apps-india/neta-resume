# Copy to .env and fill in. All vars are prefixed NETA_ (see neta_ingest/config.py).

NETA_DATABASE_URL=postgresql+psycopg://neta:neta@localhost:5432/neta

# DSN used by `neta migrate`/`neta seed` (needs DDL/owner privileges). Falls back to NETA_DATABASE_URL
# when unset. In CI, set this (not NETA_DATABASE_URL) on the migrate job to the Neon owner role.
# NETA_MIGRATE_DATABASE_URL=postgresql+psycopg://OWNER:PASS@HOST/neta?sslmode=require

# Polite scraping (be a good citizen — MyNeta is non-commercial/public).
NETA_HTTP_MIN_DELAY_SECONDS=1.0
NETA_HTTP_USER_AGENT=neta-resume/0.1 (non-commercial research; contact: you@example.com)

# data.gov.in API key (free, from https://data.gov.in) — only needed for the datagovin source.
# NETA_DATAGOVIN_API_KEY=
