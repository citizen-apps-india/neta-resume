# Neta-Resume environment example. Copy to .env and adjust as needed.

# --- API (FastAPI) ---
# SQLAlchemy DSN for Postgres. Uses the +psycopg (psycopg 3) driver to match the
# app default. For docker-compose, the host is the `db` service; for bare-metal
# local dev use localhost.
NETA_DATABASE_URL=postgresql+psycopg://neta:neta@localhost:5432/neta

# Comma-separated CORS allow-list the API honors (the Next.js dev/prod origin).
NETA_ALLOWED_ORIGINS=http://localhost:3000

# --- Web (Next.js) ---
# Server-side base URL the web app uses to reach the FastAPI read layer.
NETA_API_BASE=http://localhost:8000
